{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-non-main-branch.sh\"",
            "statusMessage": "Enforcing main-only branch policy"
          }
        ]
      }
    ]
  }
}
